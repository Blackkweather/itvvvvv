# Database (Required - use Vercel Postgres free tier)
DATABASE_URL="postgresql://username:password@host:port/dbname?schema=public"
DIRECT_URL="postgresql://username:password@host:port/dbname?schema=public"

# JWT Secret (Required in production - generate 64+ random chars)
JWT_SECRET="your-super-secure-jwt-secret-key-at-least-64-chars-long-change-this"

# App URL (Recommended)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"

# StreamPro Xtream Info (for M3U playlists)
XTREAM_SERVER_URL="http://localhost:8000"
STREAM_BASE_URL="http://localhost:8080"

# WhatsApp & Telegram Payment Links
WHATSAPP_NUMBER="1234567890"
TELEGRAM_BOT_USERNAME="your_bot_username"
TELEGRAM_CHANNEL_USERNAME="@your_channel"

# Stripe (if using payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Admin API Key (for manual subscription management - keep secret!)
ADMIN_API_KEY="your-secure-admin-api-key-change-this"

# Cookie Name
COOKIE_NAME="streampro_session"

# YouTube API (get from https://console.cloud.google.com)
NEXT_PUBLIC_YOUTUBE_API_KEY=""

# Redis (Upstash for rate limiting - get from https://upstash.com)
REDIS_URL="https://your-upstash.redis.io"
REDIS_TOKEN="your-redis-token"
